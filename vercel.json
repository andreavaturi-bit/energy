{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/[...path].ts": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/stats/:path*", "destination": "/api/[...path]" },
    { "source": "/api/budget/:path*", "destination": "/api/[...path]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
